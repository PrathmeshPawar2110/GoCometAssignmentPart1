# ── Standard OpenAI (use this OR the Azure block below, not both) ──────────
# OPENAI_API_KEY=sk-...

# ── Azure OpenAI (takes priority when both endpoint + key are set) ──────────
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=<your-azure-openai-key>
AZURE_OPENAI_API_VERSION=2024-08-01-preview
# The deployment name you created in Azure OpenAI Studio (e.g. my-gpt4o)
AZURE_OPENAI_DEPLOYMENT=my-gpt4o-deployment


API_SECRET_KEY=change-me-to-a-long-random-string

# Optional — defaults shown
DB_PATH=./nova_trade.db
UPLOAD_DIR=./uploads
RULES_DIR=./configs/rules
EXTRACTOR_MODEL=gpt-4o-2024-08-06
VALIDATOR_MODEL=gpt-4o
ROUTER_MODEL=gpt-4o
MAX_RETRIES_PER_AGENT=2
MAX_TOKENS_PER_JOB=20000
LANGGRAPH_RECURSION_LIMIT=15
CONFIDENCE_ESCALATE_THRESHOLD=0.60
CONFIDENCE_LOW_THRESHOLD=0.85

# Optional — production S3 storage
# S3_BUCKET=nova-trade-docs
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
